//@version=5
indicator("PlayBit EMA Frizz Continuation", "PB-EMA", overlay=true)

// Inputs
ema1Len = input.int(8, "EMA 1 Length")
ema2Len = input.int(13, "EMA 2 Length")
ema3Len = input.int(21, "EMA 3 Length")
ema4Len = input.int(34, "EMA 4 Length")
ema5Len = input.int(55, "EMA 5 Length")
signalMode = input.string("EMA Touch", "Signal Mode", options=["EMA Touch", "Continuation"])
touchEmaSource = input.string("Anchor Close", "Touch EMA", options=["EMA1", "EMA2", "EMA3", "EMA4", "EMA5", "Anchor High", "Anchor Close"])
anchorEmaLen = input.int(200, "Anchor EMA Length", minval=1)
showAnchorBand = input.bool(true, "Show Anchor EMA Band")
showBaseEmaChannel = input.bool(false, "Show Base EMA Channel")
anchorColorMode = input.string("Price Relative", "Anchor Color Mode", options=["Fixed", "Slope", "Price Relative"])
anchorHighColor = input.color(color.new(color.lime, 0), "Anchor Bull High Color")
anchorCloseColor = input.color(color.new(color.green, 0), "Anchor Bull Close Color")
anchorBearHighColor = input.color(color.new(color.red, 0), "Anchor Bear High Color")
anchorBearCloseColor = input.color(color.new(color.maroon, 0), "Anchor Bear Close Color")
anchorLineWidth = input.int(3, "Anchor Line Width", minval=1, maxval=5)
anchorFillTransparency = input.int(20, "Anchor Fill Transparency", minval=0, maxval=100)

lineColor = input.color(color.white, "Line Color")
showFill = input.bool(true, "Show Fill")
fillColorInput = input.color(color.rgb(120, 123, 134, 67), "Neutral Fill Color")

// EMAs
ema1 = ta.ema(close, ema1Len)
ema2 = ta.ema(close, ema2Len)
ema3 = ta.ema(close, ema3Len)
ema4 = ta.ema(close, ema4Len)
ema5 = ta.ema(close, ema5Len)
anchorHigh = ta.ema(high, anchorEmaLen)
anchorClose = ta.ema(close, anchorEmaLen)

// Channel boundaries
chTop = math.max(ema1, math.max(ema2, math.max(ema3, math.max(ema4, ema5))))
chBot = math.min(ema1, math.min(ema2, math.min(ema3, math.min(ema4, ema5))))

touchEma = anchorClose
if touchEmaSource == "EMA1"
    touchEma := ema1
else if touchEmaSource == "EMA2"
    touchEma := ema2
else if touchEmaSource == "EMA3"
    touchEma := ema3
else if touchEmaSource == "EMA4"
    touchEma := ema4
else if touchEmaSource == "EMA5"
    touchEma := ema5
else if touchEmaSource == "Anchor High"
    touchEma := anchorHigh

bullStack = ema1 > ema2 and ema2 > ema3 and ema3 > ema4 and ema4 > ema5
bearStack = ema1 < ema2 and ema2 < ema3 and ema3 < ema4 and ema4 < ema5
anchorSlopeUp = anchorClose >= nz(anchorClose[1], anchorClose)
anchorBull = anchorColorMode == "Fixed" ? true : anchorColorMode == "Slope" ? anchorSlopeUp : close >= anchorClose
activeAnchorHighColor = anchorBull ? anchorHighColor : anchorBearHighColor
activeAnchorCloseColor = anchorBull ? anchorCloseColor : anchorBearCloseColor

// State machine
var string trend = "NONE"
var string entryState = "IDLE"

longSignal = false
shortSignal = false
breakoutUp = false
breakoutDown = false
retestUp = false
retestDown = false
confirmUp = false
confirmDown = false

if barstate.isconfirmed
    if signalMode == "EMA Touch"
        touchedEma = low <= touchEma and high >= touchEma
        if touchedEma
            if close > touchEma
                longSignal := true
            else if close < touchEma
                shortSignal := true
    else
        breakoutUp := bullStack and close > chTop
        breakoutDown := bearStack and close < chBot

        retestUp := trend == "UP" and low <= chTop and close >= chBot
        retestDown := trend == "DOWN" and high >= chBot and close <= chTop

        confirmUp := trend == "UP" and close > chTop
        confirmDown := trend == "DOWN" and close < chBot

        if entryState == "IDLE"
            if breakoutUp
                trend := "UP"
                entryState := "WAIT_RETEST"
            else if breakoutDown
                trend := "DOWN"
                entryState := "WAIT_RETEST"

        else if entryState == "WAIT_RETEST"
            if retestUp or retestDown
                entryState := "WAIT_CONFIRM"

            if (trend == "UP" and bearStack) or (trend == "DOWN" and bullStack)
                trend := "NONE"
                entryState := "IDLE"

        else if entryState == "WAIT_CONFIRM"
            if confirmUp
                longSignal := true
            else if confirmDown
                shortSignal := true

            trend := "NONE"
            entryState := "IDLE"

// Plots
p1 = plot(showBaseEmaChannel ? ema1 : na, color=lineColor, title="EMA1")
p2 = plot(showBaseEmaChannel ? ema2 : na, color=lineColor, title="EMA2")
p3 = plot(showBaseEmaChannel ? ema3 : na, color=lineColor, title="EMA3")
p4 = plot(showBaseEmaChannel ? ema4 : na, color=lineColor, title="EMA4")
p5 = plot(showBaseEmaChannel ? ema5 : na, color=lineColor, title="EMA5")
pAnchorHigh = plot(showAnchorBand ? anchorHigh : na, color=activeAnchorHighColor, linewidth=anchorLineWidth, title="Anchor High EMA")
pAnchorClose = plot(showAnchorBand ? anchorClose : na, color=activeAnchorCloseColor, linewidth=anchorLineWidth, title="Anchor Close EMA")

fillColor = showFill ? (close < chBot ? color.new(color.red, 67) : close > chTop ? color.new(color.lime, 67) : fillColorInput) : na
fill(p1, p5, color=showBaseEmaChannel ? fillColor : na, fillgaps=true)
fill(pAnchorHigh, pAnchorClose, color=showAnchorBand ? color.new(activeAnchorCloseColor, anchorFillTransparency) : na, fillgaps=true)

// Visual markers
plotshape(longSignal, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny, text="LONG")
plotshape(shortSignal, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, text="SHORT")

// Alerts
alertcondition(longSignal, title="PB-EMA Long", message='{"secret":"YOUR_TV_WEBHOOK_SECRET","strategy_id":"pb-ema","signal_id":"{{ticker}}-{{interval}}-{{timenow}}-long","symbol":"{{ticker}}","timeframe":"{{interval}}","side":"buy","timestamp":"{{timenow}}"}')
alertcondition(shortSignal, title="PB-EMA Short", message='{"secret":"YOUR_TV_WEBHOOK_SECRET","strategy_id":"pb-ema","signal_id":"{{ticker}}-{{interval}}-{{timenow}}-short","symbol":"{{ticker}}","timeframe":"{{interval}}","side":"sell","timestamp":"{{timenow}}"}')
