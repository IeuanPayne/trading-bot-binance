# Copy to .env and fill values for live/paper execution
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Set to 'True' to use testnet endpoints (paper trading)
BINANCE_TESTNET=True
# Safety gate: must be True before any live order is allowed when BINANCE_TESTNET=False
ALLOW_LIVE_TRADING=False

# Risk circuit breakers (0 disables each breaker)
MAX_DAILY_LOSS_USDT=0
MAX_DRAWDOWN_PCT=0
MAX_CONSECUTIVE_LOSSES=0
MAX_TRADES_PER_DAY=0

# Strategy defaults
EMA1_LEN=8
EMA2_LEN=13
EMA3_LEN=21
EMA4_LEN=34
EMA5_LEN=55
SESSION=Both
LONDON_START=11
LONDON_END=20
NEWYORK_START=16
NEWYORK_END=25
SESSION_TZ_OFFSET=3
MAX_SPREAD_PIPS=3.0
MODELED_SPREAD_PIPS=0.0
PIP_SIZE=0.10

# Optional SMS alerting (Twilio)
ALERTS_ENABLED=False
ALERT_SMS_PROVIDER=twilio
ALERT_PHONE_TO=
ALERT_PHONE_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# MetaTrader 5 integration
MT5_ENABLED=False
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=
MT5_SYMBOL=BTCUSD
MT5_STATE_FILE=mt5_trading_state.db
MT5_USE_RISK_PCT=True
MT5_RISK_PCT=1.0
MT5_SL_PIPS=70
MT5_TP_PIPS=70
MT5_SLIPPAGE=30
MT5_AUTO_MAGIC=True
MT5_BASE_MAGIC=20260629
MT5_SIGNAL_DEBUG=False
